{
	"i18n": true,
	"type": "tabs",
	"items": {
		"connectionTab": {
			"type": "panel",
			"label": "Connection",
			"items": {
				"host": {
					"type": "text",
					"label": "Device IP / hostname",
					"help": "Local IP or hostname of the SunEnergyXT 500 (the device must be reachable via its local HTTP API; local mode LM=1 must be enabled).",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				},
				"pollInterval": {
					"type": "number",
					"label": "Poll interval (s)",
					"min": 1,
					"max": 3600,
					"default": 5,
					"newLine": true,
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"requestTimeout": {
					"type": "number",
					"label": "Request timeout (ms)",
					"min": 1000,
					"max": 60000,
					"default": 8000,
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				}
			}
		},
		"controlTab": {
			"type": "panel",
			"label": "Control",
			"items": {
				"controlHeader": {
					"type": "header",
					"size": 4,
					"text": "Control mode",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"controlInfo": {
					"type": "staticText",
					"text": "Choose how self-consumption is handled:",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"controlInfoOff": {
					"type": "staticText",
					"text": "•  Off — monitoring only: the adapter never writes MM / MD / GS.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"controlInfoController": {
					"type": "staticText",
					"text": "•  Adapter controller — ioBroker writes the grid setpoint (GS) from any meter state; works with ANY meter.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"controlInfoDevice": {
					"type": "staticText",
					"text": "•  Device self-regulation — bind a supported meter and let the storage regulate itself.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"controlInfoNote": {
					"type": "staticText",
					"text": "The two control modes are mutually exclusive; the adapter enforces the matching device mode (MM) and warns if it is changed externally. Requires local mode (LM=1) on the device.",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"controlMode": {
					"type": "select",
					"label": "Control mode",
					"options": [
						{ "label": "Off (monitoring only)", "value": "off" },
						{ "label": "Adapter controller (any meter)", "value": "controller" },
						{ "label": "Device self-regulation (supported meter)", "value": "device" }
					],
					"default": "off",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				},
				"controllerInfo": {
					"type": "staticText",
					"text": "The controller writes GS using feed-forward + P correction from your grid-power meter state. The adapter forces MM=0 so the device executes GS.",
					"hidden": "data.controlMode !== 'controller'",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"gridPowerStateId": {
					"type": "objectId",
					"label": "Grid-power source state",
					"help": "Foreign state holding the grid power of your house meter (e.g. a Shelly). Convention: >0 = grid draw, <0 = feed-in.",
					"hidden": "data.controlMode !== 'controller'",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 8,
					"lg": 6,
					"xl": 6
				},
				"gridPowerInverted": {
					"type": "checkbox",
					"label": "Invert source sign",
					"help": "Enable if your meter uses >0 = feed-in / <0 = draw.",
					"hidden": "data.controlMode !== 'controller'",
					"xs": 12,
					"sm": 12,
					"md": 4,
					"lg": 3,
					"xl": 3
				},
				"controllerGain": {
					"type": "number",
					"label": "Gain",
					"min": 0,
					"max": 2,
					"step": 0.05,
					"default": 0.3,
					"hidden": "data.controlMode !== 'controller'",
					"newLine": true,
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"controllerDeadBandW": {
					"type": "number",
					"label": "Dead band (W)",
					"min": 0,
					"max": 500,
					"default": 20,
					"hidden": "data.controlMode !== 'controller'",
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"controllerMinIntervalMs": {
					"type": "number",
					"label": "Min. write interval (ms)",
					"min": 1000,
					"max": 60000,
					"default": 5000,
					"hidden": "data.controlMode !== 'controller'",
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"controllerMaxPowerW": {
					"type": "number",
					"label": "Max. power (W)",
					"min": 0,
					"max": 2400,
					"default": 2400,
					"help": "2400 for the 500 Pro, 800 for the 500 Standard.",
					"hidden": "data.controlMode !== 'controller'",
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"watchdogWarnSec": {
					"type": "number",
					"label": "Watchdog warn (s)",
					"min": 5,
					"max": 3600,
					"default": 30,
					"help": "Log a warning if the grid source has no update for this long.",
					"hidden": "data.controlMode !== 'controller'",
					"newLine": true,
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"watchdogFailsafeSec": {
					"type": "number",
					"label": "Watchdog failsafe (s)",
					"min": 10,
					"max": 7200,
					"default": 180,
					"help": "Set GS to 0 (neutral) if the grid source is stale for this long.",
					"hidden": "data.controlMode !== 'controller'",
					"xs": 12,
					"sm": 6,
					"md": 3,
					"lg": 2,
					"xl": 2
				},
				"meterHeader": {
					"type": "header",
					"size": 5,
					"text": "Supported meter (bound into the storage)",
					"hidden": "data.controlMode !== 'device'",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"meterInfo": {
					"type": "staticText",
					"text": "The adapter binds this meter into the storage (MM=1 + MD) and lets the device regulate itself; it does not write GS. Only the four meter types below are supported, and the meter must be reachable by the storage on the local network. Note: the meter stays usable in ioBroker (it is only polled over HTTP).",
					"hidden": "data.controlMode !== 'device'",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
					"xl": 12
				},
				"meterType": {
					"type": "select",
					"label": "Meter type",
					"options": [
						{ "label": "EcoTracker (direct / IP)", "value": "ecotracker" },
						{ "label": "Shelly 3EM", "value": "shelly3em" },
						{ "label": "Shelly Pro 3EM", "value": "shellypro3em" },
						{ "label": "Tasmota", "value": "tasmota" }
					],
					"default": "shellypro3em",
					"hidden": "data.controlMode !== 'device'",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				},
				"meterId": {
					"type": "text",
					"label": "Meter SN / IP",
					"help": "Meter serial number for Shelly/Tasmota (mDNS); the LAN IP for EcoTracker (direct). For Tasmota use the SN prefix without the last 4 characters.",
					"hidden": "data.controlMode !== 'device'",
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4
				},
				"meterTasmotaSubtype": {
					"type": "select",
					"label": "Tasmota meter subtype",
					"help": "Your Tasmota / BitShake energy-monitor subtype (from the device API reference, section 5.4). The adapter derives the correct power key (dat_str.pwr) from it.",
					"hidden": "data.controlMode !== 'device' || data.meterType !== 'tasmota'",
					"newLine": true,
					"xs": 12,
					"sm": 12,
					"md": 6,
					"lg": 4,
					"xl": 4,
					"options": [
						{ "label": "APOX", "value": "APOX" },
						{ "label": "LEPUS", "value": "LEPUS" },
						{ "label": "Norax", "value": "Norax" },
						{ "label": "PICUS", "value": "PICUS" },
						{ "label": "GS303", "value": "GS303" },
						{ "label": "DWZE12", "value": "DWZE12" },
						{ "label": "DWS7410", "value": "DWS7410" },
						{ "label": "DWS7412", "value": "DWS7412" },
						{ "label": "DWS7420", "value": "DWS7420" },
						{ "label": "DWS7612", "value": "DWS7612" },
						{ "label": "DWSB12", "value": "DWSB12" },
						{ "label": "DWSB20", "value": "DWSB20" },
						{ "label": "DWSE20", "value": "DWSE20" },
						{ "label": "M60", "value": "M60" },
						{ "label": "Q3A", "value": "Q3A" },
						{ "label": "Q3B", "value": "Q3B" },
						{ "label": "Q3C", "value": "Q3C" },
						{ "label": "Q3D", "value": "Q3D" },
						{ "label": "Q1A", "value": "Q1A" },
						{ "label": "Q3M", "value": "Q3M" },
						{ "label": "eBZ", "value": "eBZ" },
						{ "label": "SGM", "value": "SGM" },
						{ "label": "AS2020", "value": "AS2020" },
						{ "label": "AS3500", "value": "AS3500" },
						{ "label": "eBZD", "value": "eBZD" },
						{ "label": "ED300L", "value": "ED300L" },
						{ "label": "ED300S", "value": "ED300S" },
						{ "label": "EMH", "value": "EMH" },
						{ "label": "HBZ", "value": "HBZ" },
						{ "label": "DTZ", "value": "DTZ" },
						{ "label": "EHZ", "value": "EHZ" },
						{ "label": "MT175", "value": "MT175" },
						{ "label": "MT176", "value": "MT176" },
						{ "label": "MT382", "value": "MT382" },
						{ "label": "MT631", "value": "MT631" },
						{ "label": "MT681", "value": "MT681" },
						{ "label": "MT691", "value": "MT691" },
						{ "label": "Itron", "value": "Itron" },
						{ "label": "KAIFA", "value": "KAIFA" },
						{ "label": "E220", "value": "E220" },
						{ "label": "E320", "value": "E320" },
						{ "label": "L20", "value": "L20" },
						{ "label": "Smarty", "value": "Smarty" },
						{ "label": "SML", "value": "SML" }
					]
				}
			}
		}
	}
}
